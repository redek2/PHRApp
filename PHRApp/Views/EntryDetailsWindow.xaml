<Window x:Class="PHRApp.Views.EntryDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szczegóły wpisu"
        Height="600"
        Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Tytuł" FontWeight="Bold"/>
            <TextBlock Text="{Binding Entry.Title}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Opis" FontWeight="Bold"/>
            <TextBlock Text="{Binding Entry.Description}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Data zdarzenia" FontWeight="Bold"/>
                <TextBlock Text="{Binding Entry.EventDate, StringFormat={}{0:yyyy-MM-dd}}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Status" FontWeight="Bold"/>
                <TextBlock Text="{Binding Entry.Status}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Kategorie" FontWeight="Bold"/>
            <TextBlock Text="{Binding Entry.CategoryNameDisplay}"/>
        </StackPanel>

        <GroupBox Grid.Row="4"
          Header="Załączniki"
          Margin="0,0,0,10">
            <ListBox ItemsSource="{Binding Entry.Attachments}"
             x:Name="AttachmentsListBox">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <EventSetter Event="MouseDoubleClick" Handler="OnAttachmentDoubleClicked"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FileName}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <TextBlock Grid.Row="5"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Otwórz plik"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="OnOpenFileClicked"/>
            <Button Content="Edytuj"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="OnEditClicked"/>
            <Button Content="Zamknij"
                    Width="100"
                    Click="OnCloseClicked"/>
        </StackPanel>

    </Grid>
</Window>