<Window x:Class="PHRApp.Views.AddEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj wpis"
        Height="700"
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Tytuł"/>
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Opis"/>
            <TextBox Text="{Binding Description}"
                     AcceptsReturn="True"
                     Height="120"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Date + Status -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Data zdarzenia"/>
                <DatePicker SelectedDate="{Binding EventDate}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Status"/>
                <ComboBox
                    ItemsSource="{Binding AvailableStatuses}"
                    SelectedItem="{Binding Status}"/>
            </StackPanel>
        </Grid>

        <!-- Categories -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Kategorie"/>

            <ListBox ItemsSource="{Binding AvailableCategories}"
                     DisplayMemberPath="Name"
                     Height="120"/>
        </StackPanel>

        <!-- Attachments -->
        <GroupBox Grid.Row="4"
                  Header="Załączniki"
                  Margin="0,0,0,10">

            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding SelectedFilePaths}"/>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">

                    <Button Content="Dodaj plik"
                            Width="100"
                            Margin="0,0,10,0"/>

                    <Button Content="Usuń plik"
                            Width="100"/>
                </StackPanel>

            </Grid>

        </GroupBox>

        <!-- Error -->
        <TextBlock Grid.Row="5"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Anuluj"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="OnCancelClicked"/>

            <Button Content="Zapisz"
                    Width="100"
                    Click="OnSaveClicked"/>
        </StackPanel>

    </Grid>

</Window>