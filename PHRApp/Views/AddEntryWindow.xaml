<Window x:Class="PHRApp.Views.AddEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PHRApp.Views.Controls"
        Title="Dodaj wpis"
        Height="700"
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Tytuł"/>
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Opis"/>
            <TextBox Text="{Binding Description}"
                     AcceptsReturn="True"
                     Height="120"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Data zdarzenia"/>
                <DatePicker SelectedDate="{Binding EventDate}"/>
            </StackPanel>

            <controls:TimePickerControl Grid.Column="2"
                                SelectedTime="{Binding EventTime, Mode=TwoWay}"/>

            <StackPanel Grid.Column="4">
                <TextBlock Text="Status"/>
                <ComboBox ItemsSource="{Binding AvailableStatuses}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding Status}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Kategorie"/>

            <ListBox ItemsSource="{Binding AvailableCategories}"
                     Height="120">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="+ Dodaj kategorię"
                        Width="130"
                        Command="{Binding AddCategoryCommand}"/>
            </Grid>
        </StackPanel>

        <GroupBox Grid.Row="4"
                  Header="Załączniki"
                  Margin="0,0,0,10">

            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox x:Name="AttachmentsListBox"
                         Grid.Row="0"
                         ItemsSource="{Binding SelectedFilePaths}"/>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">

                    <Button Content="Dodaj plik"
                            Width="100"
                            Margin="0,0,10,0"
                            Click="OnAddFileClicked"/>

                    <Button Content="Usuń plik"
                            Width="100"
                            Click="OnRemoveFileClicked"/>
                </StackPanel>

            </Grid>

        </GroupBox>

        <TextBlock Grid.Row="5"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Anuluj"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="OnCancelClicked"/>

            <Button Content="Zapisz"
                    Width="100"
                    Click="OnSaveClicked"/>
        </StackPanel>

    </Grid>

</Window>